# ===== LLM Provider (Vercel AI Gateway) =====
# 키 하나 + base_url 하나로 여러 제공사 모델을 OpenAI 호환 방식으로 호출한다.
AI_GATEWAY_API_KEY=
# Vercel AI Gateway 대시보드에서 정확한 base URL 확인 후 사용 (OpenAI 호환 v1 엔드포인트)
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ----- 선택 가능 모델 (모델 픽커 참고용 후보 목록) -----
# ✅ 모델 카탈로그(선택지·표시명·기본값·검증)의 단일 출처는 자바 백엔드(GET /models).
#    ai-server는 요청에 실려 온 slug를 그대로 실행할 뿐, 목록/기본값을 갖지 않는다.
# 아래 slug는 게이트웨이 카탈로그와 대조 완료(2026-07-22). 버전 표기는 하이픈이 아니라 점.
#   google/gemini-3.1-pro-preview
#   google/gemini-2.5-pro
#   google/gemini-3.5-flash
#   anthropic/claude-opus-4.8
#   anthropic/claude-opus-4.7
#   anthropic/claude-opus-4.6
#   openai/gpt-4o-mini   (테스트용)

# ===== Chat LLM (메인 캐릭터 응답) =====
# 모델명은 게이트웨이 형식 provider/model. 위 목록 참고.
# CHAT_MODEL은 요청에 model이 안 실려 왔을 때의 폴백(개발/전환기용) — 평상시엔 백엔드가 항상 보낸다.
CHAT_MODEL=openai/gpt-4o-mini
CHAT_TEMPERATURE=0.8
CHAT_MAX_TOKENS=512
CHAT_TIMEOUT=30
CHAT_MAX_RETRIES=2
# 게이트웨이는 chat completions 경유 → OpenAI Responses API 안 씀
CHAT_USE_RESPONSES_API=false

# ===== Summary LLM (대화 요약) =====
SUMMARY_MODEL=openai/gpt-4o-mini
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=512
SUMMARY_TIMEOUT=30
SUMMARY_MAX_RETRIES=2
SUMMARY_USE_RESPONSES_API=false

# ===== 자바 ↔ 파이썬 내부 인증 =====
# 백엔드와 공유하는 정적 시크릿. 루트 .env의 INTERNAL_AUTH_SECRET과 반드시 동일 값.
# 백엔드가 X-Internal-Auth 헤더로 전송 → ai-server가 대조(불일치/누락 시 401). 예: openssl rand -hex 32
INTERNAL_AUTH_SECRET=
