# ===== LLM Provider =====
OPENAI_API_KEY=

# ===== Chat LLM (메인 캐릭터 응답) =====
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0.8
CHAT_MAX_TOKENS=512
CHAT_TIMEOUT=30
CHAT_MAX_RETRIES=2
CHAT_USE_RESPONSES_API=true

# ===== Summary LLM (대화 요약) =====
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=512
SUMMARY_TIMEOUT=30
SUMMARY_MAX_RETRIES=2
SUMMARY_USE_RESPONSES_API=true

# ===== 자바 ↔ 파이썬 내부 인증 =====
# 백엔드와 공유하는 정적 시크릿. 루트 .env의 INTERNAL_AUTH_SECRET과 반드시 동일 값.
# 백엔드가 X-Internal-Auth 헤더로 전송 → ai-server가 대조(불일치/누락 시 401). 예: openssl rand -hex 32
INTERNAL_AUTH_SECRET=
