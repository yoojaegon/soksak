# ===== LLM Provider =====
OPENAI_API_KEY=

# ===== Chat LLM (메인 캐릭터 응답) =====
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0.8
CHAT_MAX_TOKENS=512
CHAT_TIMEOUT=30
CHAT_MAX_RETRIES=2
CHAT_USE_RESPONSES_API=true

# ===== Summary LLM (대화 요약) =====
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=512
SUMMARY_TIMEOUT=30
SUMMARY_MAX_RETRIES=2
SUMMARY_USE_RESPONSES_API=true

# ===== 자바 ↔ 파이썬 내부 인증 (TODO: HMAC vs 내부 JWT 결정 필요) =====
# INTERNAL_AUTH_SECRET=
